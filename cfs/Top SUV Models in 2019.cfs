                }
            },
            "code": [
                "let filter176 = cf.Filter(\"month\")",
                "    .label(\"month\")",
                "    .operation(\"BETWEEN\")",
                "    .value([\"2019-01-01 00:00:00.000\", \"2019-01-31 23:59:59.999\"]);",
                "/* Configuration code for this widget */",
                "let provider = cf.provider(\"Elasticsearch\");",
                "let source = provider.source(\"us_new_suv_sales_2019\");",
                "//<end filter176>",
                "let grid = cf.Grid().right(20).left(10);",
                "// Define the time field to be used",
                "let field = cf.Attribute(\"month\").func(\"MONTH\");",
                "let myData = source.timeField(field);",
                "// Define chart options",
                "// ['#f7fbff','#deebf7','#c6dbef','#9ecae1','#6baed6','#4292c6','#2171b5','#08519c','#08306b']",
                "let theme = {",
                "    top: \"#2171b5\",",
                "    mid: \"#08519c\",",
                "    bottom: \"#08306b\",",
                "    ticks: \"yellow\",",
                "    selection: \"#e9e9e9\" // Range selection",
                "};",
                "let color = cf.Color().theme(theme);",
                "myData.clientFilter(filter176);",
                "//<end exec filter176>",
                "let myChart = myData.graph(\"Time Slider\")",
                "    .set(\"grid\", grid)",
                "    .set(\"color\", color)",
                "    .set(\"player\", {",
                "    \"enable\": true,",
                "    \"pin-left\": true,",
                "    \"step\": 1,",
                "    \"step-unit\": \"month\",",
                "    \"refresh\": 1.5,",
                "    \"animation-delay\": 0.4,",
                "    \"live\": false,",
                "    \"autoplay\": false,",
                "})",
                "    .execute();",
                ""
            ],
