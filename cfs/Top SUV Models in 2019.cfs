                "moved": false,
                "static": false
            },
            "title": "Top 20 SUV Models by Sales in 2019",
            "visualization": "Bars",
            "source": {
                "name": "us_new_suv_sales_2019",
                "provider": {
                    "name": "Elasticsearch",
                    "type": "elasticsearch"
                }
            },
            "code": [
                "let filter176 = cf.Filter(\"month\")",
                "    .label(\"month\")",
                "    .operation(\"BETWEEN\")",
                "    .value([\"2019-01-01 00:00:00.000\", \"2019-01-31 23:59:59.999\"]);",
                "/* Configuration code for this widget */",
                "let provider = cf.provider(\"Elasticsearch\");",
                "let source = provider.source(\"us_new_suv_sales_2019\");",
                "//<end filter176>",
                "// Define metrics",
                "let metric0 = cf.Metric(\"sales\", \"sum\");",
                "// Define attributes to group by",
                "let group1 = cf.Attribute(\"Model\")",
                "    .limit(20)",
                "    .sort(\"desc\", metric0);",
                "// Add metrics and groups to data source",
                "let myData = source.groupby(group1)",
                "    .metrics(metric0);",
                "// Define chart options",
                "// Define Grid",
                "let grid = cf.Grid()",
                "    .top(10)",
                "    .right(135)",
                "    .bottom(25)",
                "    .left(25);",
                "// Define Color Palette",
                "let color = cf.Color()",
                "    .palette([\"#ff0029\", \"#377eb8\", \"#66a61e\", \"#984ea3\", \"#00d2d5\", \"#ff7f00\", \"#af8d00\", \"#7f80cd\", \"#b3e900\", \"#c42e60\", \"#a65628\", \"#f781bf\"]);",
                "color.match({",
                "    \"Toyota RAV4\": \"#ff0029\",",
                "    \"Toyota 4Runner\": \"#ff0029\",",
                "    \"Toyota Highlander\": \"#ff0029\",",
                "    \"Honda CR-V\": \"#377eb8\",",
                "    \"Honda Pilot\": \"#377eb8\",",
                "    \"Nissan Rogue\": \"#66a61e\",",
                "    \"Chevrolet Equinox\": \"#984ea3\",",
                "    \"Chevrolet Traverse\": \"#984ea3\",",
                "    \"GMC Acadia\": \"#00d2d5\",",
                "    \"GMC Terrain\": \"#00d2d5\",",
                "    \"Ford Escape\": \"#ff7f00\",",
                "    \"Ford Explorer\": \"#ff7f00\",",
                "    \"Ford Edge\": \"#ff7f00\",",
                "    \"Jeep Cherokee\": \"#af8d00\",",
                "    \"Jeep Grand Cherokee\": \"#af8d00\",",
                "    \"Jeep Wrangler\": \"#af8d00\",",
                "    \"Jeep Compass\": \"#af8d00\",",
                "    \"Subaru Outback\": \"#7f80cd\",",
                "    \"Subaru CrossTrek\": \"#7f80cd\",",
                "    \"Subaru Forester\": \"#7f80cd\",",
                "    \"Mazda CX-5\": \"#b3e900\",",
                "    \"Hyundai Tuscon\": \"#c42e60\",",
                "    \"Hyundai Santa Fe\": \"#c42e60\"",
                "});",
                "myData.filter(filter176);",
                "//<end exec filter176>",
                "let myChart = myData.graph(\"Bars\")",
                "    .set(\"grid\", grid)",
                "    .set(\"color\", color)",
                "    .set(\"orientation\", \"horizontal\")",
                "    .set(\"axisLabels\", false)",
                "    .set(\"xAxis\", { \"show\": true, \"lines\": true, \"max\": 450000, position: \"top\" })",
                "    .set(\"yAxis\", { \"text\": \"out\", \"lines\": false })",
                "    .set(\"dataZoom\", false)",
                "    .set(\"metricMarker\", {",
                "    show: true,",
                "    margin: 35,",
                "    fontSize: 15,",
                "    fontColor: \"black\",",
                "    iconSize: [40, 30],",
                "    iconOffset: [40, 0],",
                "    icon: [",
                "        {",
                "            name: \"Toyota RAV4\",",
                "            icon: \"image://data:image/jpeg;base64,\",",
                "            iconSize: [42, 32]",
                "        },",
                "        {",
