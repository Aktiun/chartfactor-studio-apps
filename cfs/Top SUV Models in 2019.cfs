{
    "id": "d1326551-def4-474a-858a-ac685aafde77",
    "name": "Top SUV Models in 2019",
    "description": "Replays history of SUV sales in the United States by model",
    "state": "home",
    "readOnly": false,
    "hasBorder": false,
    "thumbnailPath": "data/topsuvs.gif",
    "widgetList": [
        {
            "id": "vis51d9125d-6e6a-495b-8a37-b0be503997f9",
